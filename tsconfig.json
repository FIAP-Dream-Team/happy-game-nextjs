{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@privateComponents/*": [
        "./src/app/(private)/_components/*"
      ],
      "@publicComponents/*": [
        "./src/app/(public)/_components/*"
      ],
      "@home/*": [
        "./src/app/(public)/(home)/*"
      ],
      "@providers/*": [
        "./src/providers/*"
      ],
      "@feed/*": [
        "./src/app/(private)/feed/*"
      ],
      "@perfil/*": [
        "./src/app/(private)/perfil/*"
      ],
      "@login/*": [
        "./src/app/(public)/login/*"
      ],
      "@cadastro/*": [
        "./src/app/(public)/cadastro/*"
      ],
      "@feedback/*": [
        "./src/app/(public)/feedback/*"
      ],
      "@historia/*": [
        "./src/app/(public)/historia/*"
      ],
      "@plataforma/*": [
        "./src/app/(public)/plataforma/*"
      ],
      "@api/*": [
        "./src/app/api/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules"
  ]
}